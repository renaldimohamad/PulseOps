generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ServiceStatus {
  UP
  DOWN
  PENDING
  UNKNOWN
  PROTECTED
  DEGRADED
}

model Service {
  id          String        @id @default(uuid())
  name        String
  url         String
  category    String
  status      ServiceStatus @default(UNKNOWN)
  latency     Int?          @default(0)
  rawStatus   Int? // Internal: HTTP Status Code (e.g., 200, 404, 500)
  lastError   String? // Internal: Error message or type
  lastChecked DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Observability Relations
  latencyLogs LatencyLog[]
  incidents   Incident[]
  alerts      Alert[]

  @@map("services")
}

model LatencyLog {
  id        String   @id @default(uuid())
  serviceId String
  latency   Int
  status    Int?
  timestamp DateTime @default(now())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, timestamp])
  @@map("latency_logs")
}

model Incident {
  id         String        @id @default(uuid())
  serviceId  String
  status     ServiceStatus
  message    String
  snapshot   Json? // Detailed response body or headers
  startedAt  DateTime      @default(now())
  resolvedAt DateTime?
  service    Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId, startedAt])
  @@map("incidents")
}

model Alert {
  id        String   @id @default(uuid())
  serviceId String
  type      String // LATENCY_THRESHOLD, STATUS_DOWN, etc
  threshold Int?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("alerts")
}
