generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ServiceStatus {
  UP
  DOWN
  PENDING
  UNKNOWN
  PROTECTED
  DEGRADED
}

model Service {
  id          String        @id @default(uuid())
  name        String
  url         String
  category    String
  status      ServiceStatus @default(UNKNOWN)
  latency     Int?          @default(0)
  rawStatus   Int? // Internal: HTTP Status Code (e.g., 200, 404, 500)
  lastError   String? // Internal: Error message or type
  lastChecked DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("services")
}
